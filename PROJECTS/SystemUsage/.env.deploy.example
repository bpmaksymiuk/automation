# Copy to .env.deploy and fill in real values. NEVER commit .env.deploy.
# The Boiler Room ships from 10-BUILD/ as a self-contained static site.

# SSH user for the deployment target
DEPLOY_USER=deploy

# SSH host name or IP
DEPLOY_HOST=boiler.example.com

# SSH port (optional; defaults to 22)
DEPLOY_PORT=22

# Remote destination directory for the deployed files
DEPLOY_PATH=/var/www/boiler/current

# Private key used by ssh and rsync (kept outside the repo)
DEPLOY_KEY_PATH=~/.ssh/boiler_deploy_ed25519

# Live URL used for post-deploy smoke verification
DEPLOY_URL=https://boiler.example.com
